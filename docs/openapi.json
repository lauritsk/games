    "/api/multiplayer/socket": {
      "get": {
        "operationId": "connectMultiplayerSocket",
        "summary": "Upgrade to the multiplayer WebSocket protocol.",
        "tags": ["Multiplayer"],
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "description": "Room code.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "playerId",
            "in": "query",
            "required": true,
            "description": "Session player id.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
