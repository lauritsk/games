{
  "name": "games",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "build": "bun run src/build.ts client",
    "build:analyze": "bun run src/build.ts analyze",
    "build:production": "bun run src/build.ts production",
    "build:server": "bun run src/build.ts server",
    "build:single": "bun run src/build.ts single",
    "typecheck": "tsc --noEmit",
    "test": "bun test --parallel test/*.test.ts",
    "test:changed": "bun test --changed",
    "test:coverage": "bun test --parallel --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage test/*.test.ts",
    "test:e2e": "playwright install chromium && playwright test",
    "test:watch": "bun --watch test/*.test.ts",
    "docs:api": "bun run src/server/api-docs.ts",
    "audit": "bun audit",
    "check": "bun run typecheck && bun run test && bun run build && bun run test:e2e"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "1.3.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6"
  },
  "packageManager": "bun@1.3.13"
}
