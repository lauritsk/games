{
  "name": "classic-games",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build": "bun build ./index.html --outdir=dist --minify",
    "build:single": "bun build --compile --target=browser ./index.html --outdir=dist-single --minify",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun --watch test",
    "check": "bun run typecheck && bun test && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
